# Server Configuration
PORT=5000
NODE_ENV=production

# Database Configuration (MySQL / TiDB Cloud)
# Option 1: Connection string (recommended for TiDB Cloud)
# Format: mysql://user:password@host:4000/mcms?ssl-mode=VERIFY_IDENTITY
MYSQL_URL=

# Option 2: Individual connection params
DB_HOST=your-mysql-host.com
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=mcms
DB_PORT=3306

# Enable SSL (required for TiDB Cloud)
DB_SSL=true

# JWT Secret
JWT_SECRET=your_very_secure_jwt_secret_change_this

# Frontend URL (for CORS)
FRONTEND_URL=https://your-frontend.onrender.com
