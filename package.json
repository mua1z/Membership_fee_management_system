{
  "name": "mcms-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "npm run dev --workspace=backend",
    "dev": "npm run dev --workspace=backend & npm run dev --workspace=frontend",
    "build:frontend": "npm run build --workspace=frontend",
    "build:backend": "npm run build --workspace=backend",
    "build": "npm install --include=dev && npm run build:frontend"
  },

  "dependencies": {
    "axios": "^1.16.0",
    "bcryptjs": "^3.0.3",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.22.3",
    "sequelize": "^6.37.8",
    "uuid": "^14.0.0",
    "typescript": "^5",
    "vite": "^5.0.8"
  },

  "devDependencies": {
  }
}


